{
    "headers": [
        {
            "source": "/bot-docs/(.*\\.md)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "text/plain; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=300"
                }
            ]
        },
        {
            "source": "/bot-docs/manifest.json",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/json; charset=utf-8"
                },
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=300"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/:path*",
            "destination": "/index.html"
        }
    ],
    "trailingSlash": false
}